{
  "description": "Cortex Memory Lifecycle hooks for Claude",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__SESSION_START_HOOK__"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__USER_PROMPT_HOOK__"
          }
        ]
      }
    ]
  }
}
